# axiom.env — opt-in CLIENT routing profile for the Axiom-TTT proxy.
#
# WHAT THIS IS
# ------------
# Source this file in a SEPARATE shell from the one running the proxy to
# redirect Anthropic SDK / Claude CLI traffic through Axiom on 127.0.0.1:3000:
#
#     source ./axiom.env
#
# It is deliberately NOT auto-loaded and does NOT modify your global config
# (~/.claude/settings.json, ~/.bashrc, ~/.zshrc). Routing is per-shell and
# opt-in so it can never silently hijack your live environment.
#
# WHY A SEPARATE SHELL
# --------------------
# The proxy's own outbound bridge reads ANTHROPIC_BASE_URL to pick ITS upstream
# (see src/anthropic_forwarder.rs). If the proxy process inherits
# ANTHROPIC_BASE_URL=http://127.0.0.1:3000 it forwards to itself -> infinite
# loop. start_axiom.sh pins the server's upstream to the real API regardless,
# but keep client redirection in its own shell to stay safe.
#
#   Shell A (server):   ./start_axiom.sh           # upstream = real Anthropic
#   Shell B (client):   source ./axiom.env         # ANTHROPIC_BASE_URL -> proxy
#                       claude ...                  # or any Anthropic SDK call

# --- Client redirection ----------------------------------------------------
# Point Anthropic SDKs / the Claude CLI at the local proxy.
export ANTHROPIC_BASE_URL="http://127.0.0.1:3000"

# Your real Anthropic key. The proxy needs this to reach the upstream API; the
# key is only ever sent to https://api.anthropic.com (verified in
# anthropic_forwarder.rs). Set it in your own secret store — do not commit it.
#   export ANTHROPIC_API_KEY="sk-ant-..."

# --- Deterministic TTT sessions (X-Axiom-Session-Id) -----------------------
# The proxy keys each session's fast-weight tensor (W̃) by session id. To make
# consecutive prompts progressively adapt the SAME tensor (instead of minting a
# fresh transient session per request), pin a stable id via the
# X-Axiom-Session-Id request header. Precedence in the server is:
#     X-Axiom-Session-Id header  >  body "session_id"  >  transient UUID
#
# A raw SDK / curl client sets it directly:
#     curl -H "X-Axiom-Session-Id: my-stable-session" ...
#
# The Claude CLI forwards custom headers via ANTHROPIC_CUSTOM_HEADERS. Pick one
# stable id per logical working session so its context keeps compounding:
export ANTHROPIC_CUSTOM_HEADERS="X-Axiom-Session-Id: ${AXIOM_SESSION_ID:-axiom-dev-session}"

# Override the pinned id per shell before sourcing, e.g.:
#   AXIOM_SESSION_ID=ticket-1234 source ./axiom.env

# ---------------------------------------------------------------------------
# OPTIONAL: global Claude CLI wiring (~/.claude/settings.json)
# ---------------------------------------------------------------------------
# We do NOT apply this for you — it would route ALL Claude CLI traffic through
# the proxy globally. If you want that, merge the following "env" block into
# ~/.claude/settings.json by hand. Remove it to revert to talking to Anthropic
# directly.
#
# {
#   "env": {
#     "ANTHROPIC_BASE_URL": "http://127.0.0.1:3000",
#     "ANTHROPIC_CUSTOM_HEADERS": "X-Axiom-Session-Id: your-deterministic-session-id"
#   }
# }
#
# Conceptually you are sending:
#     ANTHROPIC_BASE_URL -> http://127.0.0.1:3000        (routes traffic to Axiom)
#     header X-Axiom-Session-Id: your-deterministic-session-id   (pins the TTT session)
#
# IMPORTANT — there is NO top-level "headers" key in settings.json. The Claude
# CLI emits custom outbound request headers via the ANTHROPIC_CUSTOM_HEADERS
# env var ("Header-Name: value", newline-separated for multiple). That is why
# the deterministic session header is wired INSIDE the "env" block above rather
# than a separate "headers": { "X-Axiom-Session-Id": "..." } object — the
# latter is not part of the settings schema and would be silently ignored.
# The Axiom server reads this header with precedence:
#     X-Axiom-Session-Id  >  body "session_id"  >  minted transient UUID
#
# Notes:
#   * Leave ANTHROPIC_API_KEY out of settings.json; let the CLI's normal
#     credential resolution provide it, or export it in your shell.
#   * The proxy must be running (./start_axiom.sh) before the CLI starts, or
#     every request will fail to connect on 127.0.0.1:3000.

echo "[axiom.env] client routing -> $ANTHROPIC_BASE_URL"
echo "[axiom.env] pinned session  -> ${ANTHROPIC_CUSTOM_HEADERS#X-Axiom-Session-Id: }"
if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
    echo "[axiom.env] NOTE: ANTHROPIC_API_KEY is unset; export it before live calls."
fi
